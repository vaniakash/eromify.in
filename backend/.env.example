# Environment Variables for ai-video-backend
# Copy this file to .env and fill in your values

# MongoDB (same as eromify)
MONGODB_URI=mongodb+srv://...

# Pollinations API key
POLLINATIONS_API_KEY=sk_...

# Cloudinary (same as eromify)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Shared secret between Next.js and this backend
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VIDEO_BACKEND_SECRET=your_random_secret_here

# Port (Render sets this automatically)
PORT=3001
